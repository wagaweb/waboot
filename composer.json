{
    "name": "waga/waboot",
    "description": "A boilerplate theme for WordPress",
    "type": "project",
    "config": {
        "platform": {
            "php": "8.3"
        }
    },
    "require": {
        "league/csv": "~9.22.0",
        "monolog/monolog": "^3.8",
        "spatie/array-to-xml": "~2.15.0",
        "illuminate/database": "v8.83.27"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Waga",
            "email": "dev@waga.it"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
